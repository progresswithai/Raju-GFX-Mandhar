{
  "rewrites": [
    {
      "source": "/wp-content/:match*",
      "destination": "/designflash.in/wp-content/:match*"
    },
    {
      "source": "/wp-includes/:match*",
      "destination": "/designflash.in/wp-includes/:match*"
    },
    {
      "source": "/wp-json/:match*",
      "destination": "/designflash.in/wp-json/:match*"
    },
    {
      "source": "/images/:match*",
      "destination": "/designflash.in/images/:match*"
    }
  ]
}
